{
  "name": "lepus",
  "private": true,
  "version": "0.0.1",
  "description": "Automated invoice service powered by AI",
  "author": "Marcus Fan marcusfan06@gmail.com",
  "main": "./dist/main.js",
  "scripts": {
    "dev:vite": "vite",
    "dev:electron": "tsc -p electron/tsconfig.json && electron dist/main.js",
    "dev": "concurrently -k \"npm run dev:vite\" \"wait-on http://localhost:5173 && NODE_ENV=development npm run dev:electron\"",
    "build": "vite build && tsc -p electron/tsconfig.json",
    "start": "npm run build && electron dist/main.js"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@fontsource-variable/dm-sans": "^5.2.8",
    "@remixicon/react": "^4.9.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "electron-toolkit": "^1.0.24",
    "next-themes": "^0.4.6",
    "node-oracledb": "^1.0.2",
    "oracledb": "^7.0.0",
    "radix-ui": "^1.6.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "^8.0.1",
    "shadcn": "^4.12.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^24.13.2",
    "@types/oracledb": "^7.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "oxlint": "^1.69.0",
    "tailwindcss": "^4.3.1",
    "typescript": "~6.0.2",
    "vite": "^8.1.0",
    "wait-on": "^9.0.10"
  }
}
